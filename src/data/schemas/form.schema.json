{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Form",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["type", "label"],
    "properties": {
      "id":    { "type": "string" },
      "type":  {
        "type": "string",
        "enum": ["boolean", "string", "number", "radio", "multiple", "photo", "textarea", "section"]
      },
      "label":   { "type": "string" },
      "options": { "type": "array", "items": { "type": "string" } },
      "min":     { "type": "number" },
      "max":     { "type": "number" }
    }
  }
}
