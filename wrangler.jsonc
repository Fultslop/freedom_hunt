{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "gwc-2026",
  "main": "src/worker.js",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "r2_buckets": [
    {
      "binding": "PHOTOS",
      "bucket_name": "gwc-2026-photos"
    }
  ],
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
